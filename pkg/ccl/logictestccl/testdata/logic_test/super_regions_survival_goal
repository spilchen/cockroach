# LogicTest: multiregion-15node-5region-3azs

# Tests for per-super-region survival goals (ALTER DATABASE ... ALTER SUPER
# REGION ... SURVIVE ...).

statement ok
SET enable_super_regions = 'on'

# --------------------------------------------------------------------------
# Setup: create a database with 5 regions and two super regions.
# sr_east has 3 regions: ap-southeast-2, us-east-1, ca-central-1
# sr_west has 2 regions: us-central-1, us-west-1
# --------------------------------------------------------------------------

statement ok
CREATE DATABASE srsg PRIMARY REGION "us-east-1"
  REGIONS "ap-southeast-2", "ca-central-1", "us-central-1", "us-west-1"

statement ok
ALTER DATABASE srsg ADD SUPER REGION "sr_east" VALUES "ap-southeast-2", "ca-central-1", "us-east-1"

statement ok
ALTER DATABASE srsg ADD SUPER REGION "sr_west" VALUES "us-central-1", "us-west-1"

# --------------------------------------------------------------------------
# a. Basic ALTER SUPER REGION SURVIVE operations.
# --------------------------------------------------------------------------

subtest basic_operations

# SURVIVE REGION FAILURE succeeds for sr_east (3 regions).
statement ok
ALTER DATABASE srsg ALTER SUPER REGION sr_east SURVIVE REGION FAILURE

# SURVIVE ZONE FAILURE always succeeds.
statement ok
ALTER DATABASE srsg ALTER SUPER REGION sr_west SURVIVE ZONE FAILURE

# Reset both to inherit from database.
statement ok
ALTER DATABASE srsg ALTER SUPER REGION sr_east SURVIVE DEFAULT

statement ok
ALTER DATABASE srsg ALTER SUPER REGION sr_west SURVIVE DEFAULT

subtest end

